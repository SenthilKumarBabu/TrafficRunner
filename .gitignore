# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# User-specific files
*.suo
*.user
*.sln.docstates

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Visual Studio profiler
*.psess
*.vsp

# Build results
[Dd]ebug/
[Rr]elease/
